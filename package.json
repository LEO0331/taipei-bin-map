{
  "name": "taipei-bin-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.cjs",
    "fetch:drinking-fountains": "tsx scripts/fetchDrinkingFountains.ts",
    "convert:drinking-fountains": "tsx scripts/convertDrinkingFountains.ts",
    "data:fetch:timed-collection": "tsx scripts/fetchTimedCollectionPoints.ts",
    "data:convert:timed-collection": "tsx scripts/convertTimedCollectionPoints.ts",
    "data:fetch:direct-drinking": "tsx scripts/fetchDirectDrinkingStations.ts",
    "data:convert:direct-drinking": "tsx scripts/convertDirectDrinkingStations.ts",
    "data:fetch:used-clothing": "tsx scripts/fetchUsedClothingRecyclingBoxes.ts",
    "data:convert:used-clothing": "tsx scripts/convertUsedClothingRecyclingBoxes.ts",
    "data:fetch:lactation-rooms": "tsx scripts/fetchLactationRooms.ts",
    "data:convert:lactation-rooms": "tsx scripts/convertLactationRooms.ts && tsx scripts/buildLactationRoomSummary.ts",
    "data:fetch:riverside-toilets": "tsx scripts/fetchRiversideToilets.ts",
    "data:convert:riverside-toilets": "tsx scripts/convertRiversideToilets.ts",
    "data:fetch:family-friendly-toilets": "tsx scripts/fetchFamilyFriendlyToilets.ts",
    "data:convert:family-friendly-toilets": "tsx scripts/convertFamilyFriendlyToilets.ts",
    "data:build:toilet-summaries": "tsx scripts/buildToiletSummaries.ts",
    "data:fetch:motorcycle-inspection-stations": "tsx scripts/fetchMotorcycleInspectionStations.ts",
    "data:convert:motorcycle-inspection-stations": "tsx scripts/convertMotorcycleInspectionStations.ts && tsx scripts/buildMotorcycleInspectionStationSummary.ts",
    "data:fetch:electric-motorcycle-charging-stations": "tsx scripts/fetchElectricMotorcycleChargingStations.ts",
    "data:convert:electric-motorcycle-charging-stations": "tsx scripts/convertElectricMotorcycleChargingStations.ts && tsx scripts/buildElectricMotorcycleChargingStationSummary.ts",
    "data:fetch:commercial-ev": "tsx scripts/fetchCommercialEvChargingSwapStations.ts",
    "data:convert:commercial-ev": "tsx scripts/convertCommercialEvChargingSwapStations.ts && tsx scripts/buildCommercialEvChargingSwapStationSummary.ts",
    "data:fetch:gas-lpg-stations": "tsx scripts/fetchGasLpgStations.ts",
    "data:convert:gas-lpg-stations": "tsx scripts/convertGasLpgStations.ts && tsx scripts/buildGasLpgStationSummary.ts",
    "data:fetch:designated-smoking-areas": "tsx scripts/fetchDesignatedSmokingAreas.ts",
    "data:convert:designated-smoking-areas": "tsx scripts/convertDesignatedSmokingAreas.ts",
    "data:fetch:no-smoking": "tsx scripts/fetchAnnouncedNoSmokingPlaces.ts",
    "data:convert:no-smoking": "tsx scripts/convertAnnouncedNoSmokingPlaces.ts",
    "data:fetch:community-recycling": "tsx scripts/fetchCommunityRecyclingStations.ts",
    "data:convert:community-recycling": "tsx scripts/convertCommunityRecyclingStations.ts",
    "data:fetch:clean-needle": "tsx scripts/fetchCleanNeedleExchangeServicePoints.ts",
    "data:convert:clean-needle": "tsx scripts/convertCleanNeedleExchangeServicePoints.ts",
    "data:fetch:protected-trees": "tsx scripts/fetchProtectedTrees.ts",
    "data:convert:protected-trees": "tsx scripts/convertProtectedTrees.ts",
    "data:fetch:pay-taipei-parking": "tsx scripts/fetchPayTaipeiCardlessParkingLots.ts",
    "data:convert:pay-taipei-parking": "tsx scripts/convertPayTaipeiCardlessParkingLots.ts",
    "data:fetch:green-space-adoption": "tsx scripts/fetchGreenSpaceAdoptionRecords.ts",
    "data:convert:green-space-adoption": "tsx scripts/convertGreenSpaceAdoptionRecords.ts && tsx scripts/buildGreenSpaceAdoptionSummary.ts",
    "convert:bins": "tsx scripts/convertBins.ts",
    "convert:facilities": "tsx scripts/convertBins.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "iconv-lite": "^0.6.3",
    "leaflet": "^1.9.4",
    "papaparse": "^5.5.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "15.0.7",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "5.4.21",
    "vitest": "3.2.6"
  }
}
